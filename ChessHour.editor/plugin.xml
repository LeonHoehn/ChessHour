<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.0"?>

<!--
-->

<plugin>

   <extension point="org.eclipse.ui.newWizards">
      <!-- @generated chessHour -->
      <category
            id="org.eclipse.emf.ecore.Wizard.category.ID"
            name="%_UI_Wizard_category"/>
      <wizard
            id="chessHour.presentation.ChessHourModelWizardID"
            name="%_UI_ChessHourModelWizard_label"
            class="chessHour.presentation.ChessHourModelWizard"
            category="org.eclipse.emf.ecore.Wizard.category.ID"
            icon="icons/full/obj16/ChessHourModelFile.gif">
         <description>%_UI_ChessHourModelWizard_description</description>
         <selection class="org.eclipse.core.resources.IResource"/>
      </wizard>
   </extension>

   <extension point="org.eclipse.ui.editors">
      <!-- @generated chessHour -->
      <editor
            id="chessHour.presentation.ChessHourEditorID"
            name="%_UI_ChessHourEditor_label"
            icon="icons/full/obj16/ChessHourModelFile.gif"
            extensions="chesshour"
            class="chessHour.presentation.ChessHourEditor"
            contributorClass="chessHour.presentation.ChessHourActionBarContributor">
      </editor>
   </extension>

<extension point="org.eclipse.ui.commands">
  <command
      id="ChessHour.editor.generateCommand"
      name="Puzzle generieren">
  </command>
</extension>

<extension point="org.eclipse.ui.menus">
  <menuContribution
      allPopups="true"
      locationURI="popup:org.eclipse.jdt.ui.PackageExplorer?endof=group.edit">
    <command
        commandId="ChessHour.editor.generateCommand"
        label="Puzzle generieren"
        style="push">
    </command>
  </menuContribution>
  <menuContribution
      allPopups="true"
      locationURI="popup:org.eclipse.ui.navigator.ProjectExplorer?endof=additions">
    <command
        commandId="ChessHour.editor.generateCommand"
        label="Puzzle generieren"
        style="push">
    </command>
  </menuContribution>
</extension>

<extension point="org.eclipse.ui.handlers">
  <handler
      commandId="ChessHour.editor.generateCommand"
      class="editor.handler.PuzzleGenerationHandler">
    <enabledWhen>
      <with variable="selection">
        <count value="1"/>
        <iterate operator="and" ifEmpty="false">
          <adapt type="org.eclipse.core.resources.IFile">
            <test
                property="org.eclipse.core.resources.extension"
                value="chesshour">
            </test>
          </adapt>
        </iterate>
      </with>
    </enabledWhen>
  </handler>
</extension>
</plugin>
